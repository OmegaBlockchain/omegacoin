   </property>
   <item>
    <widget class="QLabel" name="labelStepIndicator">
     <property name="text">
      <string>Step 1 of 4</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
     <property name="styleSheet">
      <string>font-weight: bold; font-size: 10pt; color: #888;</string>
     </property>
    </widget>
   </item>
   <item>
    <widget class="QStackedWidget" name="stackedWidget">
     <property name="currentIndex">
      <number>0</number>
     </property>
     <!-- Page 0: Welcome -->
     <widget class="QWidget" name="pageWelcome">
      <layout class="QVBoxLayout" name="welcomeLayout">
       <item>
        <spacer name="welcomeTopSpacer">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
        </spacer>
       </item>
       <item>
        <widget class="QLabel" name="labelWelcomeTitle">
         <property name="text">
          <string>Create a Masternode</string>
         </property>
         <property name="alignment">
          <set>Qt::AlignCenter</set>
         </property>
         <property name="styleSheet">
          <string>font-size: 14pt; font-weight: bold;</string>
         </property>
        </widget>
       </item>
       <item>
        <spacer name="welcomeMidSpacer1">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>15</height>
          </size>
         </property>
        </spacer>
       </item>
       <item>
        <widget class="QLabel" name="labelWelcomeText">
         <property name="text">
          <string>To create a masternode you must dedicate 1000 coins to the network as collateral. These coins remain in your wallet and are still yours - they never leave your possession.

You can deactivate the masternode and unlock the coins at any time.

This wizard will guide you through the setup process:
1. Enter your server IP address
2. Generate keys and addresses
3. Review and register

You will need a server (VPS) with a static IP address already running the masternode daemon before proceeding.</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
         <property name="alignment">
          <set>Qt::AlignLeft|Qt::AlignVCenter</set>
         </property>
        </widget>
       </item>
       <item>
        <spacer name="welcomeBottomSpacer">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
     <!-- Page 1: Server Configuration -->
     <widget class="QWidget" name="pageServer">
      <layout class="QVBoxLayout" name="serverLayout">
       <item>
        <spacer name="serverTopSpacer">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
        </spacer>
       </item>
       <item>
        <widget class="QLabel" name="labelServerTitle">
         <property name="text">
          <string>Server Configuration</string>
         </property>
         <property name="styleSheet">
          <string>font-size: 12pt; font-weight: bold;</string>
         </property>
         <property name="alignment">
          <set>Qt::AlignCenter</set>
         </property>
        </widget>
       </item>
       <item>
        <spacer name="serverMidSpacer1">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>15</height>
          </size>
         </property>
        </spacer>
       </item>
       <item>
        <widget class="QLabel" name="labelServerDesc">
         <property name="text">
          <string>Enter the IP address of your masternode server (VPS). The port will be set automatically to the default network port.</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout" name="ipLayout">
         <item>
          <widget class="QLabel" name="labelIp">
           <property name="text">
            <string>IP Address:</string>
           </property>
           <property name="minimumWidth">
            <number>100</number>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QLineEdit" name="lineEditIpAddress">
           <property name="placeholderText">
            <string>e.g. 123.45.67.89</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
       <item>
        <layout class="QHBoxLayout" name="portLayout">
         <item>
          <widget class="QLabel" name="labelPort">
           <property name="text">
            <string>Port:</string>
           </property>
           <property name="minimumWidth">
            <number>100</number>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QLineEdit" name="lineEditPort">
           <property name="placeholderText">
            <string>7777</string>
           </property>
           <property name="readOnly">
            <bool>true</bool>
           </property>
          </widget>
         </item>
        </layout>
       </item>
       <item>
        <spacer name="serverBottomSpacer">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
     <!-- Page 2: Keys & Addresses -->
     <widget class="QWidget" name="pageKeys">
      <layout class="QVBoxLayout" name="keysLayout">
       <item>
        <widget class="QLabel" name="labelKeysTitle">
         <property name="text">
          <string>Keys and Addresses</string>
         </property>
         <property name="styleSheet">
          <string>font-size: 12pt; font-weight: bold;</string>
         </property>
         <property name="alignment">
          <set>Qt::AlignCenter</set>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="labelKeysDesc">
         <property name="text">
          <string>Click "Generate" to create all required keys and addresses. The BLS operator secret key must be placed in the masternode daemon configuration file on your server.</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPushButton" name="btnGenerate">
         <property name="text">
          <string>Generate Keys and Addresses</string>
         </property>
        </widget>
       </item>
       <item>
        <layout class="QFormLayout" name="keysFormLayout">
         <property name="verticalSpacing">
          <number>8</number>
         </property>
         <item row="0" column="0">
          <widget class="QLabel" name="labelOwnerAddrLabel">
           <property name="text">
            <string>Owner Address:</string>
           </property>
          </widget>
         </item>
         <item row="0" column="1">
          <widget class="QLineEdit" name="lineEditOwnerAddress">
           <property name="readOnly">
            <bool>true</bool>
           </property>
          </widget>
         </item>
         <item row="1" column="0">
          <widget class="QLabel" name="labelPayoutAddrLabel">
           <property name="text">
            <string>Payout Address:</string>
           </property>
          </widget>
         </item>
         <item row="1" column="1">
          <widget class="QLineEdit" name="lineEditPayoutAddress">
           <property name="readOnly">
            <bool>true</bool>
           </property>
          </widget>
         </item>
         <item row="2" column="0">
          <widget class="QLabel" name="labelBlsPubLabel">
           <property name="text">
            <string>BLS Public Key:</string>
           </property>
          </widget>
         </item>
         <item row="2" column="1">
          <widget class="QLineEdit" name="lineEditBlsPublicKey">
           <property name="readOnly">
            <bool>true</bool>
           </property>
          </widget>
         </item>
         <item row="3" column="0">
          <widget class="QLabel" name="labelBlsSecretLabel">
           <property name="text">
            <string>BLS Secret Key:</string>
           </property>
          </widget>
         </item>
         <item row="3" column="1">
          <widget class="QLineEdit" name="lineEditBlsSecretKey">
           <property name="readOnly">
            <bool>true</bool>
           </property>
          </widget>
         </item>
        </layout>
       </item>
       <item>
        <widget class="QLabel" name="labelBlsWarning">
         <property name="text">
          <string>IMPORTANT: Copy the BLS Secret Key above and add it to the masternode.conf on your server as:
masternodeblsprivkey=&lt;BLS Secret Key&gt;</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
         <property name="styleSheet">
          <string>color: #c0392b; font-weight: bold;</string>
         </property>
        </widget>
       </item>
       <item>
        <spacer name="keysBottomSpacer">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
     <!-- Page 3: Review & Confirm -->
     <widget class="QWidget" name="pageConfirm">
      <layout class="QVBoxLayout" name="confirmLayout">
       <item>
